get.nuts <- function(x){
out <- substr(x, 1,5)
out <- sub("_", "", out, fixed=TRUE)
return(out)
}
get.yr <- function(x){
x <- as.character(x)
len <- nchar(x)
out <- substr(x, len-4, len)
out <-as.numeric(out)
return(out)
}

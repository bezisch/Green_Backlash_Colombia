str_detect(data[,v],no)
new <- data.frame(row = 1:nrow(data))
cbind(new,str_detect(data[,v],no))
lookfor <- function(no, data, vars){
no <- as.character(no) %>%
str_remove("\\(")
new <- data.frame(row = 1:nrow(data))
for(v in vars){
new <- cbind(new,str_detect(data[,v],no))
}
out <- rowSums(new[,2:ncol(new)])
return(out>0)
}
lookfor("dog", dt, vars)
dt
lookfor("cat", dt, vars)
lookfor("mouse", dt, vars)
